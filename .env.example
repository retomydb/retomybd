# =============================================================================
# retomY - Environment Configuration Template
# Copy to .env and fill in real values
# =============================================================================

# ── MSSQL Database ───────────────────────────────────────
MSSQL_HOST=host.docker.internal
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=CHANGE_ME_IN_PRODUCTION
MSSQL_DATABASE=retomY
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# ── Azure Storage ────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=devstoreaccount1
AZURE_STORAGE_ACCOUNT_KEY=CHANGE_ME
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=CHANGE_ME;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
AZURE_BLOB_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1
AZURE_QUEUE_ENDPOINT=http://127.0.0.1:10001/devstoreaccount1
AZURE_TABLE_ENDPOINT=http://127.0.0.1:10002/devstoreaccount1
AZURE_STORAGE_API_VERSION=2021-12-02

# ── JWT / Auth ───────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Backend API ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_VERSION=v1
API_TITLE=retomY API
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=retomY

# ── Application ──────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
PLATFORM_COMMISSION_RATE=0.15
MAX_UPLOAD_SIZE_MB=500
ALLOWED_FILE_TYPES=csv,json,parquet,xlsx,tsv,xml,zip,gz

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_TEST_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET
STRIPE_PLATFORM_ACCOUNT_ID=
FRONTEND_URL=http://localhost:3000
